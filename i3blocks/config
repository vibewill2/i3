align=left

[cpu]
command=/home/vibewill/.config/i3blocks/scripts/cpu
interval=5
color=#ffffff
align=left

[memory]
command=/home/vibewill/.config/i3blocks/scripts/memory
interval=5
color=#ffffff
align=left

[network]
command=/home/vibewill/.config/i3blocks/scripts/network
interval=5
color=#ffffff
align=left

[battery]
command=/home/vibewill/.config/i3blocks/scripts/battery
