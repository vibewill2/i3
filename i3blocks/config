# i3blocks config com ícones (sem opções que quebram sua versão)
separator=false
separator_block_width=15
markup=pango

[thunar]
command=/home/vibewill/.config/i3blocks/scripts/thunar
interval=once
color=#ffffff
align=left

[chrome]
command=/home/vibewill/.config/i3blocks/scripts/chrome
interval=once
color=#ffffff
align=left

[volume]
command=/home/vibewill/.config/i3blocks/scripts/volume
