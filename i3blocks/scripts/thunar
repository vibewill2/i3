#!/usr/bin/env bash

# Ícone do Thunar (usa ícone genérico de pasta)
ICON=""

# Se clicar com o botão esquerdo, abre o Thunar
if [ "$BLOCK_BUTTON" = "1" ]; then
  if command -v thunar >/dev/null 2>&1; then
    nohup thunar >/dev/null 2>&1 &
  fi
fi
# Mostra apenas o ícone na barra (amarelo)

echo "<span foreground='#e5c07b'>$ICON</span>"
