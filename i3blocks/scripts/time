#!/usr/bin/env bash

CLOCK_COLOR="#61afef"   # azul para o ├¡cone de hora
DATE_COLOR="#e5c07b"    # amarelo para o ├¡cone de data

now_time=$(date +'%H:%M')
now_date=$(date +'%d/%m/%Y')

echo "<span foreground='${CLOCK_COLOR}'>´Çù</span> ${now_time}  <span foreground='${DATE_COLOR}'>´ü│</span> ${now_date}"
