#!/usr/bin/env bash

# Ícone do Google Chrome (usa ícone genérico de navegador)
ICON=""

# Se clicar com o botão esquerdo, abre o Google Chrome
if [ "$BLOCK_BUTTON" = "1" ]; then
  # Tenta o comando "google-chrome". Se não existir, tenta "google-chrome-stable".
  if command -v google-chrome >/dev/null 2>&1; then
    nohup google-chrome >/dev/null 2>&1 &
  elif command -v google-chrome-stable >/dev/null 2>&1; then
    nohup google-chrome-stable >/dev/null 2>&1 &
  fi
fi
# Mostra apenas o ícone na barra (azul)

echo "<span foreground='#61afef'>$ICON</span>"
